{
  "name": "longform-reader",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "API_PORT=34567 node --watch api/server.js",
    "dev:web": "vite --host 0.0.0.0 --port 45678",
    "start": "NODE_ENV=production node api/server.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@mozilla/readability": "latest",
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "express": "latest",
    "jsdom": "latest",
    "lucide-react": "latest",
    "vite": "latest",
    "typescript": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {}
}
